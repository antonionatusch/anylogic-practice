					<Parameters>
						<Parameter>
							<Name><![CDATA[onExit]]></Name>
							<Value Class="CodeValue">
								<Code><![CDATA[if (agent.tipo == 1){
	// estacion manjar
	agent.tiempo = triangular(7,9,13);
	enter2.take(agent);
};
/*
	el agente tipo 3 es aquel que 
	sale del manjar
*/

if (agent.tipo == 3){
	agent.tiempo = triangular(9,10,11);
	enter3.take(agent);
	agent.tipo = 1; // vuelve a ser alfajor
};

if (agent.tipo == 2){
	enter4.take(agent);
};]]></Code>
							</Value>
						</Parameter>
					</Parameters>
